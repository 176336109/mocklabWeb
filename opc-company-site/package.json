  "scripts": {
    "dev": "..\\\\hugo.exe server --disableFastRender",
    "build": "..\\\\hugo.exe --gc --minify",
    "preview": "..\\\\hugo.exe server --disableFastRender -e production",
    "format": "prettier -w ."
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "prettier": "^3.8.1",
    "prettier-plugin-go-template": "0.0.15",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwind-bootstrap-grid": "^7.0.0",
    "tailwindcss": "^4.2.1"
  }
}
